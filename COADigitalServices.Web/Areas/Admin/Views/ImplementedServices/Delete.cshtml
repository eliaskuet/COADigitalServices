@model COADigitalServices.Data.Models.ImplementedService
@{
    ViewData["Title"] = "Delete Implemented Service";
}

<h1>Delete Implemented Service</h1>

<div class="alert alert-danger">
    <p>Are you sure you want to delete service '<strong>@Model.ServiceName</strong>'?</p>
</div>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ServiceId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-secondary" href="/Admin/ImplementedServices">Cancel</a>
</form>
