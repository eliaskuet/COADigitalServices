@section css
{
    <style>
        * {
            box-sizing: border-box;
        }

        #myInput {
            background-image: url('/assets/img/searchicon.png');
            background-position: 10px 10px;
            background-repeat: no-repeat;
            width: 100%;
            font-size: 26px;
            padding: 12px 20px 12px 40px;
            border: 1px solid #ddd;
            margin-bottom: 12px;
            border-color: gray;
        }

        .btn-group-lg > .btn, .btn-lg {
            padding: 1.5rem 3rem;
            font-size: 2.5rem;
            line-height: 2.5;
            border-radius: 1.5rem 15px;
            margin-top: 15px;
        }
    </style>
}

@section scripts
{
    <script>

        function myFunction() {
            debugger;
            var input, filter, table, tr, td, i, txtValue;
            input = document.getElementById("myInput");
            if (input.value != null && input.value != "" && input.value != '') {
                $(".breakPoint").css("display", "none");
            }
            else {
                $(".breakPoint").css("display", "block");
            }
            filter = input.value.toUpperCase();
            table = document.getElementById("divCol");
            tr = table.getElementsByTagName("a");
            for (i = 0; i < tr.length; i++) {
                td = tr[i];
                if (td) {
                    txtValue = td.textContent || td.innerText;
                    if (txtValue.toUpperCase().indexOf(filter) > -1) {
                        tr[i].style.display = "";
                    } else {
                        tr[i].style.display = "none";
                    }
                }
            }
        }
    </script>
}