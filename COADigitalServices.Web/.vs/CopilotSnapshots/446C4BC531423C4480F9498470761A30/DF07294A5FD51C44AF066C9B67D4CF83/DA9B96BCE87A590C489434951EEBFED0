using System.Threading.Tasks;
using Microsoft.Extensions.DependencyInjection;
using Microsoft.EntityFrameworkCore;
using COADigitalServices.Data.Models;
using System.Security.Cryptography;
using System.Text;

namespace COADigitalServices.BLL.Seed
{
    public static class SeedData
    {
        public static async Task SeedAsync(IServiceProvider services)
        {
            using var scope = services.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();

n            // Ensure database exists
            await db.Database.EnsureCreatedAsync();

n            // Seed users
            if (!await db.Users.AnyAsync(u => u.Username == "admin"))
            {
                db.Users.Add(new User
                {
                    Username = "admin",
                    PasswordHash = ComputeSha256Hash("password"),
                    Role = "Admin"
                });
            }

n            if (!await db.Users.AnyAsync(u => u.Username == "user1"))
            {
                db.Users.Add(new User
                {
                    Username = "user1",
                    PasswordHash = ComputeSha256Hash("userpass"),
                    Role = "User"
                });
            }

n            if (!await db.Users.AnyAsync(u => u.Username == "manager"))
            {
                db.Users.Add(new User
                {
                    Username = "manager",
                    PasswordHash = ComputeSha256Hash("managerpass"),
                    Role = "Manager"
                });
            }

n            await db.SaveChangesAsync();
        }

n        private static string ComputeSha256Hash(string rawData)
        {
            using var sha256Hash = SHA256.Create();
            var bytes = sha256Hash.ComputeHash(Encoding.UTF8.GetBytes(rawData));
            var builder = new StringBuilder();
            for (int i = 0; i < bytes.Length; i++)
                builder.Append(bytes[i].ToString("x2"));
            return builder.ToString();
        }
    }
}
