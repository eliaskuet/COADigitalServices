@model COADigitalServices.Areas.Admin.Controllers.UsersController.EditUserModel
@{
    ViewData["Title"] = "Edit User";
}

<h1>Edit User</h1>

<form asp-action="Edit" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div class="col-md-6">
        <label asp-for="Username" class="form-label"></label>
        <input asp-for="Username" class="form-control" />
        <span asp-validation-for="Username" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Password" class="form-label">Password (leave blank to keep current)</label>
        <input asp-for="Password" class="form-control" type="password" />
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Role" class="form-label"></label>
        <input asp-for="Role" class="form-control" />
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-primary">Save</button>
        <a class="btn btn-secondary" href="/Admin/Users">Back to list</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
